generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Price {
  id        Int      @id @default(autoincrement())
  price     Float
  timestamp DateTime @default(now())
}
